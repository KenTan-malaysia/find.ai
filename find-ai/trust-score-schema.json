{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chinese Business License Trust Score Data Model",
  "description": "Comprehensive schema for Chinese business entity verification and trust scoring, used by Find.ai for evaluating landlord/tenant risk in Malaysian property rental context.",
  "type": "object",
  "required": [
    "uscc",
    "companyNameCN",
    "companyNameEN",
    "registeredCapital",
    "operatingStatus",
    "operatingStatus",
    "registrationDate",
    "legalRepresentative"
  ],
  "properties": {
    "companyIdentification": {
      "type": "object",
      "description": "Core company identification information",
      "required": ["uscc", "companyNameCN", "companyNameEN", "legalRepresentative"],
      "properties": {
        "uscc": {
          "type": "string",
          "pattern": "^[0-9A-HJ-NP-RT-UW-Y]{18}$",
          "description": "Unified Social Credit Code (统一社会信用代码) - 18-character identifier issued by Chinese government. Format: 18 alphanumeric characters [0-9A-HJ-NP-RT-UW-Y]. Valid character set excludes I, O, Z, S, V to avoid confusion.",
          "example": "914403001234567890"
        },
        "companyNameCN": {
          "type": "string",
          "description": "Official company name in Simplified Chinese (公司名称)",
          "example": "深圳市腾讯计算机系统有限公司"
        },
        "companyNameEN": {
          "type": "string",
          "description": "Official company name in English (English translation or official English name)",
          "example": "Shenzhen Tencent Computer Systems Co., Ltd."
        },
        "legalRepresentative": {
          "type": "string",
          "description": "Name of legal representative/company principal (法定代表人). Usually the founder or designated director.",
          "example": "马化腾"
        },
        "registeredAddress": {
          "type": "string",
          "description": "Registered office address in China (注册地址)",
          "example": "深圳市南山区科技生态园11栋"
        },
        "businessAddresses": {
          "type": "array",
          "description": "List of operational business addresses (经营地址)",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "registration": {
      "type": "object",
      "description": "Company registration and capitalization details",
      "required": ["registeredCapital", "registrationDate", "registrationAuthority"],
      "properties": {
        "registeredCapital": {
          "type": "object",
          "description": "Registered capital (注册资本) - Legal capital commitment, basis for financial stability scoring",
          "required": ["amount", "currency"],
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0,
              "description": "Capital amount in base units",
              "example": 330000000
            },
            "currency": {
              "type": "string",
              "enum": ["CNY", "USD", "EUR", "HKD"],
              "description": "Currency of capital amount (typically CNY for Chinese companies)",
              "example": "CNY"
            },
            "formattedAmount": {
              "type": "string",
              "description": "Human-readable formatted amount with currency",
              "example": "330,000,000 CNY"
            }
          }
        },
        "paidInCapital": {
          "type": "object",
          "description": "Paid-in capital (实缴资本) - Actual capital paid into company treasury",
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0,
              "description": "Paid-in amount",
              "example": 330000000
            },
            "currency": {
              "type": "string",
              "enum": ["CNY", "USD", "EUR", "HKD"],
              "description": "Currency of paid-in capital",
              "example": "CNY"
            },
            "percentage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Percentage of registered capital paid in",
              "example": 100
            }
          }
        },
        "registrationDate": {
          "type": "string",
          "format": "date",
          "description": "Company registration date (注册时间) - Date of initial business registration",
          "example": "2000-11-11"
        },
        "operatingPeriod": {
          "type": "object",
          "description": "Operating license period (经营期限)",
          "properties": {
            "start": {
              "type": "string",
              "format": "date",
              "description": "Operating period start date",
              "example": "2000-11-11"
            },
            "end": {
              "type": "string",
              "format": "date",
              "description": "Operating period end date (null or empty indicates perpetual)",
              "example": "2050-11-10"
            },
            "isPerpetutal": {
              "type": "boolean",
              "description": "Whether operating period is perpetual (no end date)",
              "example": false
            }
          }
        },
        "registrationAuthority": {
          "type": "string",
          "description": "Government authority that issued registration (登记机关) - Usually provincial/city market supervision bureau",
          "example": "深圳市市场监督管理局"
        },
        "registrationType": {
          "type": "string",
          "enum": ["Limited Liability", "Joint Stock", "Partnership", "Sole Proprietorship", "Other"],
          "description": "Type of business entity registration",
          "example": "Limited Liability"
        }
      }
    },
    "operatingStatus": {
      "type": "object",
      "description": "Current operational status and any abnormalities",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "revoked", "cancelled", "liquidated"],
          "description": "Current operating status. 'active' = normal operations, 'revoked/cancelled' = no longer valid, 'liquidated' = dissolution in progress",
          "example": "active"
        },
        "statusDescription": {
          "type": "string",
          "description": "Human-readable status description",
          "example": "Company is currently active and in good standing"
        },
        "lastStatusChangeDate": {
          "type": "string",
          "format": "date",
          "description": "Date of most recent status change",
          "example": "2026-04-15"
        },
        "abnormalOperations": {
          "type": "boolean",
          "description": "Flag indicating abnormal operations recorded by authorities (异常经营)",
          "example": false
        },
        "abnormalDetails": {
          "type": "array",
          "description": "List of abnormal operations or violations (异常情况详情)",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Type of abnormality",
                "example": "未按规定报送年度报告"
              },
              "description": {
                "type": "string",
                "description": "Detailed description of abnormality",
                "example": "Failed to submit annual report as required"
              },
              "recordDate": {
                "type": "string",
                "format": "date",
                "description": "Date abnormality was recorded"
              },
              "resolved": {
                "type": "boolean",
                "description": "Whether abnormality has been resolved",
                "example": false
              }
            }
          }
        }
      }
    },
    "legalCompliance": {
      "type": "object",
      "description": "Legal status and compliance records (25% of trust score)",
      "properties": {
        "dishonestDebtor": {
          "type": "boolean",
          "description": "Whether company is listed as 失信被执行人 (dishonest debtor/judgment debtor). Binary gate: if true, trust score = 0.",
          "example": false
        },
        "dishonestDebtorDetails": {
          "type": "object",
          "description": "Details about dishonest debtor status if applicable",
          "properties": {
            "caseNumber": {
              "type": "string",
              "description": "Court case number",
              "example": "(2024)深圳市法执字001号"
            },
            "executionAmount": {
              "type": "number",
              "description": "Amount to be executed in CNY",
              "example": 5000000
            },
            "listedDate": {
              "type": "string",
              "format": "date",
              "description": "Date added to dishonest debtor list"
            },
            "court": {
              "type": "string",
              "description": "Responsible court",
              "example": "Shenzhen Intermediate People's Court"
            }
          }
        },
        "activeLawsuits": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of active court lawsuits (民事诉讼). Penalty: -5 points per lawsuit (max -15 points)",
          "example": 2
        },
        "lawsuitDetails": {
          "type": "array",
          "description": "List of active lawsuit details",
          "items": {
            "type": "object",
            "properties": {
              "caseNumber": {
                "type": "string",
                "description": "Court case number",
                "example": "(2025)深圳市一中民初001号"
              },
              "court": {
                "type": "string",
                "description": "Court handling the case",
                "example": "Shenzhen Intermediate People's Court"
              },
              "filedDate": {
                "type": "string",
                "format": "date",
                "description": "Date lawsuit was filed"
              },
              "plaintiff": {
                "type": "string",
                "description": "Plaintiff party name"
              },
              "defendant": {
                "type": "string",
                "description": "Defendant party name"
              },
              "claimAmount": {
                "type": "number",
                "description": "Amount claimed in CNY",
                "example": 1000000
              },
              "status": {
                "type": "string",
                "enum": ["pending", "ongoing", "settled", "closed"],
                "description": "Current status of lawsuit"
              }
            }
          }
        },
        "administrativePenalties": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of administrative penalties on record (行政处罚). Penalty: -3 points each (max -10 points)",
          "example": 1
        },
        "penaltyDetails": {
          "type": "array",
          "description": "List of administrative penalties",
          "items": {
            "type": "object",
            "properties": {
              "penaltyNumber": {
                "type": "string",
                "description": "Penalty decision number",
                "example": "深圳市场(罚)〔2024〕001号"
              },
              "authority": {
                "type": "string",
                "description": "Authority that issued penalty",
                "example": "Shenzhen Market Supervision Bureau"
              },
              "issueDate": {
                "type": "string",
                "format": "date",
                "description": "Date penalty was issued"
              },
              "type": {
                "type": "string",
                "description": "Type of violation",
                "example": "Unauthorized advertisement"
              },
              "fineAmount": {
                "type": "number",
                "description": "Fine amount in CNY (if applicable)",
                "example": 50000
              },
              "status": {
                "type": "string",
                "enum": ["active", "paid", "appealed"],
                "description": "Status of penalty"
              }
            }
          }
        },
        "courtRecords": {
          "type": "array",
          "description": "Other court records and judgments",
          "items": {
            "type": "object",
            "properties": {
              "recordType": {
                "type": "string",
                "description": "Type of court record",
                "example": "Enforcement"
              },
              "description": {
                "type": "string",
                "description": "Description of record",
                "example": "Judgment enforcement"
              },
              "date": {
                "type": "string",
                "format": "date",
                "description": "Date of record"
              }
            }
          }
        }
      }
    },
    "taxCompliance": {
      "type": "object",
      "description": "Tax compliance status (15% of trust score)",
      "required": ["taxRating"],
      "properties": {
        "taxRating": {
          "type": "string",
          "enum": ["A", "B", "C", "D"],
          "description": "Tax authority credit rating. A=15pts (excellent), B=11pts (good), C=6pts (fair), D=0pts (poor)",
          "example": "A"
        },
        "ratingDescription": {
          "type": "string",
          "description": "Narrative description of tax rating",
          "example": "Excellent tax compliance, timely filing and payment"
        },
        "taxID": {
          "type": "string",
          "pattern": "^[0-9A-Z]{15,20}$",
          "description": "Tax identification number (税号/纳税人识别号)",
          "example": "91440300123456789X"
        },
        "lastRatingDate": {
          "type": "string",
          "format": "date",
          "description": "Date of most recent tax rating assessment",
          "example": "2026-01-15"
        },
        "filingCompliance": {
          "type": "boolean",
          "description": "Whether company has filed all required tax returns",
          "example": true
        },
        "paymentCompliance": {
          "type": "boolean",
          "description": "Whether company has paid all taxes owed",
          "example": true
        },
        "taxArrears": {
          "type": "number",
          "description": "Outstanding tax debt in CNY (0 if compliant)",
          "example": 0
        }
      }
    },
    "businessInformation": {
      "type": "object",
      "description": "Business operations and industry details",
      "properties": {
        "businessScope": {
          "type": "string",
          "description": "Registered business scope/operations (经营范围)",
          "example": "计算机硬件及软件开发、经营、销售及相关技术服务"
        },
        "industryCategory": {
          "type": "string",
          "description": "Industry classification (行业分类)",
          "example": "互联网和相关服务"
        },
        "businessEscalationLevel": {
          "type": "string",
          "description": "Size classification by scope and scale",
          "enum": ["large", "medium", "small", "micro"],
          "example": "large"
        },
        "employeeCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Approximate number of employees (used for positive factor: 1000+ = significant workforce)",
          "example": 15000
        },
        "branchCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of known branch/subsidiary offices (used for positive factor: 5+ = established presence)",
          "example": 45
        },
        "stockholders": {
          "type": "array",
          "description": "List of major shareholders/stakeholders",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Stockholder name (individual or company)",
                "example": "Tencent Holdings Limited"
              },
              "type": {
                "type": "string",
                "enum": ["natural_person", "domestic_company", "foreign_company"],
                "description": "Type of stockholder",
                "example": "foreign_company"
              },
              "capitalContribution": {
                "type": "number",
                "description": "Amount contributed in CNY",
                "example": 330000000
              },
              "ownershipPercentage": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Percentage ownership",
                "example": 100
              }
            }
          }
        }
      }
    },
    "trustScoreOutput": {
      "type": "object",
      "description": "Trust score calculation results and recommendations for Malaysian landlords",
      "required": ["trustScore", "trustGrade", "trafficLight"],
      "properties": {
        "trustScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall trust score (0-100). Calculated as weighted average of 5 components. Green>=70, Yellow=40-69, Red<40",
          "example": 82
        },
        "trustGrade": {
          "type": "string",
          "enum": ["A", "B", "C", "D"],
          "description": "Letter grade based on trust score: A(80-100), B(60-79), C(40-59), D(0-39)",
          "example": "A"
        },
        "trafficLight": {
          "type": "string",
          "enum": ["green", "yellow", "red"],
          "description": "Traffic light status: Green(>=70)=safe proceed, Yellow(40-69)=caution, Red(<40)=high risk",
          "example": "green"
        },
        "scoreBreakdown": {
          "type": "object",
          "description": "Detailed breakdown of component scores and weights",
          "properties": {
            "operatingStatusScore": {
              "type": "integer",
              "minimum": 0,
              "maximum": 15,
              "description": "Operating Status component (15% weight): Active=15pts, else=0pts",
              "example": 15
            },
            "operatingStatusWeight": {
              "type": "number",
              "example": 0.15
            },
            "financialStabilityScore": {
              "type": "integer",
              "minimum": 0,
              "maximum": 25,
              "description": "Financial Stability component (25% weight): Based on registered capital tiers",
              "example": 25
            },
            "financialStabilityWeight": {
              "type": "number",
              "example": 0.25
            },
            "longevityScore": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20,
              "description": "Longevity component (20% weight): <2yr=4, 2-5yr=10, 5-10yr=16, >10yr=20",
              "example": 20
            },
            "longevityWeight": {
              "type": "number",
              "example": 0.20
            },
            "legalRiskScore": {
              "type": "integer",
              "minimum": 0,
              "maximum": 25,
              "description": "Legal Risk component (25% weight): Start=25, minus for dishonest debtor(-25), lawsuits(-5 each max -15), penalties(-3 each max -10)",
              "example": 23
            },
            "legalRiskWeight": {
              "type": "number",
              "example": 0.25
            },
            "taxComplianceScore": {
              "type": "integer",
              "minimum": 0,
              "maximum": 15,
              "description": "Tax Compliance component (15% weight): A=15, B=11, C=6, D=0",
              "example": 15
            },
            "taxComplianceWeight": {
              "type": "number",
              "example": 0.15
            }
          }
        },
        "riskFactors": {
          "type": "array",
          "description": "Array of identified risk factors for landlord consideration",
          "items": {
            "type": "string",
            "description": "Description of a risk factor",
            "example": "2 active lawsuits"
          }
        },
        "positiveFactors": {
          "type": "array",
          "description": "Array of identified positive factors supporting the company",
          "items": {
            "type": "string",
            "description": "Description of a positive factor",
            "example": "Currently active and operating"
          }
        },
        "recommendations": {
          "type": "object",
          "description": "Tailored recommendations for Malaysian landlords in multiple languages",
          "properties": {
            "en": {
              "type": "string",
              "description": "Recommendation in English",
              "example": "Green light: This company shows strong financial stability. Trust score 82/100 indicates low risk for lease agreements. Proceed with standard tenant verification procedures."
            },
            "zh": {
              "type": "string",
              "description": "Recommendation in Simplified Chinese (中文)",
              "example": "绿灯：该公司显示出强劲的财务稳定性。信任评分 82/100 表示租赁协议的风险较低。按照标准租户验证程序进行。"
            },
            "bm": {
              "type": "string",
              "description": "Recommendation in Bahasa Melayu (Malaysian)",
              "example": "Lampu hijau: Syarikat ini menunjukkan kestabilan kewangan yang kuat. Skor kepercayaan 82/100 menunjukkan risiko rendah untuk perjanjian sewaan. Sila teruskan dengan prosedur pengesahan penyewa standard."
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Metadata about the verification record",
      "properties": {
        "dataSource": {
          "type": "string",
          "description": "Source of company information (usually National Credit Information Public Disclosure Platform in China)",
          "example": "National Credit Information Public Disclosure Platform"
        },
        "lastVerificationDate": {
          "type": "string",
          "format": "date",
          "description": "Date of most recent verification/update from source",
          "example": "2026-04-15"
        },
        "calculationTimestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when trust score was calculated",
          "example": "2026-04-19T12:00:00Z"
        },
        "schemaVersion": {
          "type": "string",
          "description": "Version of this schema used for validation",
          "example": "1.0.0"
        },
        "verificationPurpose": {
          "type": "string",
          "description": "Purpose of verification",
          "example": "Malaysian property rental tenant verification"
        },
        "verificationStandard": {
          "type": "string",
          "description": "Standard or requirement being verified against",
          "example": "Find.ai Landlord Trust Assessment v1"
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "companyIdentification": {
        "uscc": "914403001234567890",
        "companyNameCN": "深圳市腾讯计算机系统有限公司",
        "companyNameEN": "Shenzhen Tencent Computer Systems Co., Ltd.",
        "legalRepresentative": "马化腾",
        "registeredAddress": "深圳市南山区科技生态园11栋"
      },
      "registration": {
        "registeredCapital": {
          "amount": 330000000,
          "currency": "CNY",
          "formattedAmount": "330,000,000 CNY"
        },
        "paidInCapital": {
          "amount": 330000000,
          "currency": "CNY",
          "percentage": 100
        },
        "registrationDate": "2000-11-11",
        "operatingPeriod": {
          "start": "2000-11-11",
          "end": "2050-11-10",
          "isPerpetutal": false
        },
        "registrationAuthority": "深圳市市场监督管理局",
        "registrationType": "Limited Liability"
      },
      "operatingStatus": {
        "status": "active",
        "statusDescription": "Company is currently active and in good standing",
        "abnormalOperations": false,
        "abnormalDetails": []
      },
      "legalCompliance": {
        "dishonestDebtor": false,
        "activeLawsuits": 2,
        "administrativePenalties": 1,
        "courtRecords": []
      },
      "taxCompliance": {
        "taxRating": "A",
        "ratingDescription": "Excellent tax compliance",
        "taxID": "91440300123456789X",
        "filingCompliance": true,
        "paymentCompliance": true,
        "taxArrears": 0
      },
      "businessInformation": {
        "businessScope": "计算机硬件及软件开发、经营、销售及相关技术服务",
        "industryCategory": "互联网和相关服务",
        "businessEscalationLevel": "large",
        "employeeCount": 15000,
        "branchCount": 45
      },
      "trustScoreOutput": {
        "trustScore": 82,
        "trustGrade": "A",
        "trafficLight": "green",
        "scoreBreakdown": {
          "operatingStatusScore": 15,
          "financialStabilityScore": 25,
          "longevityScore": 20,
          "legalRiskScore": 23,
          "taxComplianceScore": 15
        },
        "riskFactors": [
          "2 active lawsuits",
          "1 administrative penalty"
        ],
        "positiveFactors": [
          "Currently active and operating",
          "Strong registered capital (>= 50M CNY)",
          "Established company (25+ years operating)",
          "Excellent tax compliance (Grade A)"
        ],
        "recommendations": {
          "en": "Green light: This company shows strong financial stability and legal compliance. Proceed with standard tenant verification procedures.",
          "zh": "绿灯：该公司显示出强劲的财务稳定性和法律合规性。按照标准租户验证程序进行。",
          "bm": "Lampu hijau: Syarikat ini menunjukkan kestabilan kewangan dan pematuhan undang-undang yang kuat. Sila teruskan dengan prosedur pengesahan penyewa standard."
        }
      },
      "metadata": {
        "dataSource": "National Credit Information Public Disclosure Platform",
        "lastVerificationDate": "2026-04-15",
        "calculationTimestamp": "2026-04-19T12:00:00Z",
        "schemaVersion": "1.0.0"
      }
    }
  ]
}
